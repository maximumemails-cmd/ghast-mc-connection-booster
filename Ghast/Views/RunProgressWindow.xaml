<Window x:Class="Ghast.Views.RunProgressWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        Width="400" SizeToContent="Height"
        MinHeight="212"
        ShowInTaskbar="False"
        Background="{StaticResource BgBody}"
        FontFamily="Segoe UI"
        Foreground="{StaticResource TextWhite}">
    <Border BorderBrush="{StaticResource Stroke}" BorderThickness="1">
        <Grid Margin="26,22">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Orientation="Horizontal">
                <TextBlock x:Name="TitleText" FontSize="19" FontWeight="Bold"
                           Foreground="{StaticResource TextWhite}" />
                <Path x:Name="Check" Visibility="Collapsed" Margin="10,3,0,0"
                      Data="M 0 6 L 4 10 L 12 1" Stroke="#5FCB71" StrokeThickness="2.6"
                      StrokeStartLineCap="Round" StrokeEndLineCap="Round" VerticalAlignment="Center" />
            </StackPanel>

            <ProgressBar x:Name="Bar" Grid.Row="1" Height="10" Minimum="0" Maximum="100" Value="0"
                         Margin="0,18,0,0" Style="{StaticResource RedProgressBar}" />

            <TextBlock x:Name="StatusText" Grid.Row="2" Margin="0,14,0,0"
                       FontSize="14" FontWeight="SemiBold" Foreground="{StaticResource TextWhite}" />

            <TextBlock x:Name="StepText" Grid.Row="3" Margin="0,5,0,0" MinHeight="20"
                       FontSize="13" Foreground="{StaticResource TextMuted}" TextWrapping="Wrap" />

            <StackPanel Grid.Row="4">
                <!-- Reconnect nudge: per-interface TCP values only apply to NEW connections -->
                <Border x:Name="NudgePanel" Visibility="Collapsed"
                        Background="{StaticResource BgPanel}"
                        BorderBrush="{StaticResource Stroke}" BorderThickness="1"
                        CornerRadius="6" Padding="12,9" Margin="0,12,0,0">
                    <TextBlock FontSize="12.5" Foreground="{StaticResource TextWhite}" TextWrapping="Wrap"
                               Text="Reconnect to your server (leave and rejoin) for the TCP tweaks to take effect on your current session — Windows only reads them when a connection starts." />
                </Border>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
                    <Button x:Name="FlushButton" Content="Apply to live connection…"
                            Style="{StaticResource OutlinedRedButton}"
                            Margin="0,0,10,0" Visibility="Collapsed" Click="Flush_Click"
                            ToolTip="Briefly disables and re-enables each network adapter (~3 s) so already-open connections re-establish with the new TCP settings. It does NOT lower latency by itself — and it WILL drop your server session for a few seconds. Optional; reconnecting in-game does the same thing." />
                    <Button x:Name="RetryButton" Content="Retry" Style="{StaticResource OutlinedRedButton}"
                            Margin="0,0,10,0" Visibility="Collapsed" Click="Retry_Click" />
                    <Button x:Name="StopButton" Content="Stop" Style="{StaticResource SolidRedButton}"
                            Margin="0,0,10,0" Visibility="Collapsed" Click="Stop_Click" />
                    <Button x:Name="CloseButton" Content="Close" Style="{StaticResource OutlinedRedButton}"
                            Visibility="Collapsed" Click="Close_Click" />
                </StackPanel>
            </StackPanel>
        </Grid>
    </Border>
</Window>
