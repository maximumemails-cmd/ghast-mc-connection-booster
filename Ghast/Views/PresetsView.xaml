<UserControl x:Class="Ghast.Views.PresetsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Margin="40,26,72,20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Top row: search + action buttons -->
        <Grid Grid.Row="0" Margin="0,0,0,26">
            <TextBox Style="{StaticResource GhastTextBox}"
                     Width="290"
                     HorizontalAlignment="Left"
                     Tag="Search Presets"
                     Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" />

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                <Button Content="Apply Selected"
                        Style="{StaticResource OutlinedRedButton}"
                        Margin="0,0,12,0"
                        Visibility="{Binding SelectMode, Converter={StaticResource BoolToVisibility}}"
                        Command="{Binding BulkApplyCommand}" />
                <Button Content="Delete Selected"
                        Style="{StaticResource OutlinedRedButton}"
                        Margin="0,0,12,0"
                        Visibility="{Binding SelectMode, Converter={StaticResource BoolToVisibility}}"
                        Command="{Binding BulkDeleteCommand}" />
                <Button Content="Export Selected"
                        Style="{StaticResource OutlinedRedButton}"
                        Margin="0,0,12,0"
                        ToolTip="Saves the selected presets as shareable .ghast files (with a version field) into a folder you pick."
                        Visibility="{Binding SelectMode, Converter={StaticResource BoolToVisibility}}"
                        Command="{Binding ExportSelectedCommand}" />
                <Button Content="Select Mode"
                        Style="{StaticResource OutlinedRedButton}"
                        Margin="0,0,12,0"
                        Command="{Binding ToggleSelectModeCommand}" />
                <Button Content="ⓘ Explain"
                        Style="{StaticResource OutlinedRedButton}"
                        Margin="0,0,12,0"
                        ToolTip="What do the built-in presets actually do?"
                        Command="{Binding ExplainCommand}" />
                <Button Content="Import Preset"
                        Style="{StaticResource OutlinedRedButton}"
                        Margin="0,0,12,0"
                        Command="{Binding ImportPresetCommand}" />
                <Button Content="Create Preset"
                        Style="{StaticResource SolidRedButton}"
                        Command="{Binding CreatePresetCommand}" />
            </StackPanel>
        </Grid>

        <!-- Preset list: two columns, drag handles reorder -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <ItemsControl ItemsSource="{Binding View}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <UniformGrid Columns="2" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Padding="10,12" Margin="0,0,24,6"
                                Background="Transparent"
                                AllowDrop="True"
                                Drop="PresetRow_Drop"
                                DragOver="PresetRow_DragOver">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <CheckBox Grid.Column="0"
                                          Style="{StaticResource GhastCheckBox}"
                                          IsChecked="{Binding IsSelected}"
                                          Margin="0,0,12,0"
                                          VerticalAlignment="Center"
                                          Visibility="{Binding DataContext.SelectMode, RelativeSource={RelativeSource AncestorType=ItemsControl}, Converter={StaticResource BoolToVisibility}}" />

                                <!-- drag handle: two stacked bars -->
                                <StackPanel Grid.Column="1"
                                            VerticalAlignment="Center"
                                            Margin="0,0,14,0"
                                            Cursor="SizeAll"
                                            Background="Transparent"
                                            MouseLeftButtonDown="DragHandle_MouseLeftButtonDown">
                                    <Rectangle Width="16" Height="3" RadiusX="1.5" RadiusY="1.5"
                                               Fill="{StaticResource TextMuted}" Margin="0,0,0,4" />
                                    <Rectangle Width="16" Height="3" RadiusX="1.5" RadiusY="1.5"
                                               Fill="{StaticResource TextMuted}" />
                                </StackPanel>

                                <TextBlock Grid.Column="2"
                                           Text="{Binding Name}"
                                           FontSize="20"
                                           FontWeight="Bold"
                                           Foreground="{StaticResource TextWhite}"
                                           VerticalAlignment="Center"
                                           TextTrimming="CharacterEllipsis" />

                                <Button Grid.Column="3"
                                        Content="Apply"
                                        Style="{StaticResource ApplySmallButton}"
                                        VerticalAlignment="Center"
                                        Command="{Binding DataContext.ApplyPresetCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                        CommandParameter="{Binding}" />
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </Grid>
</UserControl>
