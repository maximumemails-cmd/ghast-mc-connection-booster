<Window x:Class="Ghast.Views.ClosePromptDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        SizeToContent="Height"
        Width="470"
        ShowInTaskbar="False"
        Background="{StaticResource BgBody}"
        FontFamily="Segoe UI"
        Foreground="{StaticResource TextWhite}">
    <Border BorderBrush="{StaticResource Stroke}" BorderThickness="1">
        <StackPanel Margin="28,24">
            <TextBlock Text="Ghast is still active" FontSize="19" FontWeight="Bold"
                       Foreground="{StaticResource TextWhite}" />
            <TextBlock Margin="0,12,0,0" FontSize="14" TextWrapping="Wrap"
                       Foreground="{StaticResource TextWhite}"
                       Text="Ghast's tweaks are currently applied. Do you want to revert them to your original Windows settings before closing?" />

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,24,0,0">
                <Button Content="Cancel" Style="{StaticResource OutlinedRedButton}"
                        Margin="0,0,10,0" Click="Cancel_Click" />
                <Button Content="Leave Applied" Style="{StaticResource OutlinedRedButton}"
                        Margin="0,0,10,0" Click="Leave_Click" />
                <Button Content="Revert &amp; Close" Style="{StaticResource SolidRedButton}"
                        Click="Revert_Click" />
            </StackPanel>
        </StackPanel>
    </Border>
</Window>
