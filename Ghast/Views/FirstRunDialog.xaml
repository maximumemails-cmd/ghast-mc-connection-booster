<Window x:Class="Ghast.Views.FirstRunDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:Ghast.Controls"
        Title="Welcome to Ghast"
        WindowStyle="None"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        SizeToContent="Height"
        Width="480"
        ShowInTaskbar="False"
        Background="{StaticResource BgBody}"
        FontFamily="Segoe UI"
        Foreground="{StaticResource TextWhite}">
    <Border BorderBrush="{StaticResource Stroke}" BorderThickness="1">
        <StackPanel Margin="32,28">
            <TextBlock Text="Welcome to Ghast" FontSize="22" FontWeight="Bold"
                       Foreground="{StaticResource TextWhite}" HorizontalAlignment="Center" />
            <TextBlock Text="Two quick options — both off by default, both changeable any time from the Settings tab."
                       Style="{StaticResource MutedLabel}" FontSize="13" TextWrapping="Wrap"
                       TextAlignment="Center" Margin="0,10,0,0" />

            <!-- Start with Windows -->
            <Grid Margin="0,28,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Margin="0,0,16,0">
                    <TextBlock Text="Start Ghast when Windows starts" FontSize="15" FontWeight="SemiBold"
                               Foreground="{StaticResource TextWhite}" />
                    <TextBlock Text="Adds a per-user startup entry. Because Ghast needs administrator rights, Windows may still ask for permission at logon."
                               Style="{StaticResource MutedLabel}" FontSize="12" TextWrapping="Wrap"
                               Margin="0,4,0,0" />
                </StackPanel>
                <controls:PillToggle x:Name="StartupToggle" Grid.Column="1" VerticalAlignment="Top" />
            </Grid>

            <!-- Pin to taskbar -->
            <Grid Margin="0,22,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Margin="0,0,16,0">
                    <TextBlock Text="Pin Ghast to the taskbar" FontSize="15" FontWeight="SemiBold"
                               Foreground="{StaticResource TextWhite}" />
                    <TextBlock Text="Best effort — some Windows versions block apps from pinning themselves; Ghast will tell you if that happens."
                               Style="{StaticResource MutedLabel}" FontSize="12" TextWrapping="Wrap"
                               Margin="0,4,0,0" />
                </StackPanel>
                <controls:PillToggle x:Name="PinToggle" Grid.Column="1" VerticalAlignment="Top" />
            </Grid>

            <Button Content="Get Started"
                    Style="{StaticResource SolidRedButton}"
                    HorizontalAlignment="Center"
                    MinWidth="160"
                    Margin="0,30,0,0"
                    Click="GetStarted_Click" />
        </StackPanel>
    </Border>
</Window>
