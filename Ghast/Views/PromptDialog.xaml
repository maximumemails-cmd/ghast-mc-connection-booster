<Window x:Class="Ghast.Views.PromptDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        SizeToContent="Height"
        Width="420"
        ShowInTaskbar="False"
        Background="{StaticResource BgBody}"
        FontFamily="Segoe UI"
        Foreground="{StaticResource TextWhite}">
    <Border BorderBrush="{StaticResource Stroke}" BorderThickness="1">
        <StackPanel Margin="28,24">
            <TextBlock x:Name="TitleText"
                       FontSize="19" FontWeight="Bold"
                       Foreground="{StaticResource TextWhite}" />

            <TextBox x:Name="InputBox"
                     Style="{StaticResource GhastTextBox}"
                     Margin="0,18,0,0"
                     KeyDown="InputBox_KeyDown" />

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,22,0,0">
                <Button Content="Cancel" Style="{StaticResource OutlinedRedButton}"
                        Margin="0,0,12,0" Click="Cancel_Click" />
                <Button Content="Save" Style="{StaticResource SolidRedButton}" Click="Ok_Click" />
            </StackPanel>
        </StackPanel>
    </Border>
</Window>
