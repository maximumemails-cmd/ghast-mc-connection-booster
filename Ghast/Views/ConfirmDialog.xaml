<Window x:Class="Ghast.Views.ConfirmDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        SizeToContent="Height"
        Width="520"
        MaxHeight="560"
        ShowInTaskbar="False"
        Background="{StaticResource BgBody}"
        FontFamily="Segoe UI"
        Foreground="{StaticResource TextWhite}">
    <Border BorderBrush="{StaticResource Stroke}" BorderThickness="1">
        <StackPanel Margin="28,24">
            <TextBlock x:Name="TitleText"
                       FontSize="19" FontWeight="Bold"
                       Foreground="{StaticResource TextWhite}"
                       TextWrapping="Wrap" />

            <ScrollViewer MaxHeight="340" VerticalScrollBarVisibility="Auto" Margin="0,16,0,0">
                <ItemsControl x:Name="LinesList">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal" Margin="0,3">
                                <Ellipse Width="5" Height="5" Fill="{StaticResource Accent}"
                                         VerticalAlignment="Top" Margin="0,7,10,0" />
                                <TextBlock Text="{Binding}" TextWrapping="Wrap" MaxWidth="420"
                                           Foreground="{StaticResource TextWhite}" FontSize="14" />
                            </StackPanel>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,24,0,0">
                <Button Content="Cancel" Style="{StaticResource OutlinedRedButton}"
                        Margin="0,0,12,0" Click="Cancel_Click" />
                <Button x:Name="ConfirmButton" Content="Apply"
                        Style="{StaticResource SolidRedButton}" Click="Confirm_Click" />
            </StackPanel>
        </StackPanel>
    </Border>
</Window>
