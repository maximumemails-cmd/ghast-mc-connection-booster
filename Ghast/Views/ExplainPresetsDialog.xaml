<Window x:Class="Ghast.Views.ExplainPresetsDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="What do these presets do?"
        WindowStyle="None"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        Width="560" Height="620"
        ShowInTaskbar="False"
        Background="{StaticResource BgBody}"
        FontFamily="Segoe UI"
        Foreground="{StaticResource TextWhite}">
    <Border BorderBrush="{StaticResource Stroke}" BorderThickness="1">
        <Grid Margin="30,26">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Text="What do these presets do?"
                       FontSize="21" FontWeight="Bold" Foreground="{StaticResource TextWhite}" />

            <Border Grid.Row="1" Background="{StaticResource BgPanel}" CornerRadius="8"
                    Padding="16,12" Margin="0,16,0,0">
                <TextBlock x:Name="IntroText" FontSize="13" TextWrapping="Wrap"
                           Foreground="{StaticResource TextMuted}" />
            </Border>

            <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto" Margin="0,18,0,0">
                <ItemsControl x:Name="List">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Margin="0,0,10,18">
                                <TextBlock Text="{Binding Name}" FontSize="16" FontWeight="Bold"
                                           Foreground="{StaticResource TextWhite}" />
                                <TextBlock Text="{Binding Text}" FontSize="13" TextWrapping="Wrap"
                                           Foreground="{StaticResource TextMuted}" Margin="0,4,0,0" />
                            </StackPanel>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>

            <Button Grid.Row="3" Content="Close" Style="{StaticResource SolidRedButton}"
                    HorizontalAlignment="Right" Margin="0,18,0,0" MinWidth="120" Click="Close_Click" />
        </Grid>
    </Border>
</Window>
